# NoETL GUI — environment variables
# Copy this file to .env.local for local development overrides.
# .env.local is git-ignored and never committed.

# Gateway base URL (default: http://localhost:8090)
VITE_GATEWAY_URL=http://localhost:8090

# Auth0 configuration (falls back to built-in dev defaults when unset)
# VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
# VITE_AUTH0_CLIENT_ID=your-client-id
# VITE_AUTH0_REDIRECT_URI=http://localhost:3001

# Skip authentication in local development.
# When set to "true", a "Continue without Authentication" button appears on
# the login page and the UI bypasses the Gateway, calling NoETL directly on
# http://localhost:8082/api.
# The UI also requires local/private browser and API hosts before enabling it.
# Must NEVER be set to "true" in production deployments.
VITE_ALLOW_SKIP_AUTH=false
